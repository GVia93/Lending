# Backend URL
REACT_APP_BACKEND_URL=http://localhost:8001

# Google Analytics 4 Measurement ID
# Получить на https://analytics.google.com/ -> Admin -> Data Streams
# Формат: G-XXXXXXXXXX
REACT_APP_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Яндекс.Метрика Counter ID
# Получить на https://metrika.yandex.ru/ -> Создать счётчик
# Формат: 12345678
REACT_APP_YANDEX_METRIKA_ID=12345678
